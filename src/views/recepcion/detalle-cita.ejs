<% layout('layouts/main') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-file-earmark-medical text-info"></i> Ficha del Turno</h2>
        <div>
            <button class="btn btn-outline-primary me-2"><i class="bi bi-printer"></i> Imprimir Ficha</button>
            <a href="/citas" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver a la Agenda</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            
            <div class="card shadow-sm border-0 border-top border-success border-4 mb-4">
                <div class="card-body">
                    <h5 class="card-title text-success"><i class="bi bi-person-fill"></i> Datos del Paciente</h5>
                    <hr>
                    <p class="mb-1"><strong>Nombre:</strong> <%= cita.paciente?.nombre || 'Usuario' %> <%= cita.paciente?.apellido || 'Eliminado' %></p>
                    <p class="mb-1"><strong>Documento:</strong> CC <%= cita.paciente?.documento || 'N/A' %></p>
                    <p class="mb-1"><strong>Teléfono:</strong> <%= cita.paciente?.telefono || 'No registrado' %></p>
                    <p class="mb-1"><strong>EPS:</strong> <%= cita.paciente?.eps || 'Particular' %></p>
                    
                    <div class="mt-3 p-2 bg-light rounded text-danger">
                        <i class="bi bi-exclamation-triangle-fill"></i> <strong>Alergias:</strong>
                        <% if (cita.paciente?.alergias && cita.paciente.alergias.length > 0) { %>
                            <%= cita.paciente.alergias.join(', ') %>
                        <% } else { %>
                            Ninguna registrada
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-body">
                    <h5 class="card-title text-primary"><i class="bi bi-heart-pulse-fill"></i> Médico Asignado</h5>
                    <hr>
                    <p class="mb-1 text-uppercase"><strong>Dr. <%= cita.medico?.nombre || 'Médico' %> <%= cita.medico?.apellido || 'No Asignado' %></strong></p>
                    <p class="mb-0 text-muted"><i class="bi bi-envelope"></i> <%= cita.medico?.email || 'N/A' %></p>
                </div>
            </div>
            
        </div>

        <div class="col-md-8">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0">Detalles de la Consulta</h5>
                </div>
                <div class="card-body p-4">
                    
                    <div class="row mb-4">
                        <div class="col-sm-4">
                            <h6 class="text-muted mb-1">Fecha Programada</h6>
                            <p class="fs-5 fw-bold"><i class="bi bi-calendar-event text-primary"></i> <%= new Date(cita.fecha).toLocaleDateString() %></p>
                        </div>
                        <div class="col-sm-4">
                            <h6 class="text-muted mb-1">Hora</h6>
                            <p class="fs-5 fw-bold"><i class="bi bi-clock text-primary"></i> <%= cita.hora %></p>
                        </div>
                        <div class="col-sm-4">
                            <h6 class="text-muted mb-1">Estado Actual</h6>
                            <% if(cita.estado === 'Pendiente') { %>
                                <span class="badge bg-warning text-dark fs-6"><i class="bi bi-hourglass-split"></i> Pendiente</span>
                            <% } else if(cita.estado === 'Confirmada') { %>
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Confirmada</span>
                            <% } else if(cita.estado === 'Cancelada') { %>
                                <span class="badge bg-danger fs-6"><i class="bi bi-x-circle"></i> Cancelada</span>
                            <% } else { %>
                                <span class="badge bg-secondary fs-6"><i class="bi bi-check-all"></i> Completada</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-muted mb-2">Motivo de la Consulta / Notas:</h6>
                        <div class="p-3 bg-light rounded border">
                            <%= cita.motivo %>
                        </div>
                    </div>

                    <hr>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <form action="/citas/<%= cita._id %>/estado?_method=PUT" method="POST">
                            <input type="hidden" name="nuevoEstado" value="Cancelada">
                            <button type="submit" class="btn btn-outline-danger fw-bold" <%= cita.estado === 'Cancelada' ? 'disabled' : '' %>>
                                <i class="bi bi-x-circle"></i> Cancelar Cita
                            </button>
                        </form>
                        
                        <form action="/citas/<%= cita._id %>/estado?_method=PUT" method="POST">
                            <input type="hidden" name="nuevoEstado" value="Confirmada">
                            <button type="submit" class="btn btn-success fw-bold" <%= cita.estado === 'Confirmada' ? 'disabled' : '' %>>
                                <i class="bi bi-check-circle"></i> Confirmar Cita
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>