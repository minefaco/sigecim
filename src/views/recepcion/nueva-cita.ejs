<% layout('layouts/main') %>

<link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-journal-plus me-2"></i>Asignar Turno Manual</h5>
                    <a href="/citas" class="btn btn-sm btn-outline-light"><i class="bi bi-arrow-left"></i> Volver a la Agenda</a>
                </div>
                <div class="card-body p-4">
                    <form action="/citas/nueva" method="POST">
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Buscar Paciente (Nombre o Documento)</label>
                                <select id="select-paciente" name="paciente" placeholder="Escribe el documento o nombre..." autocomplete="off" required>
                                    <option value="">Buscar paciente...</option>
                                    <% pacientes.forEach(p => { %>
                                        <option value="<%= p._id %>"><%= p.documento %> - <%= p.nombre %> <%= p.apellido %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Buscar Médico</label>
                                <select id="select-medico" name="medico" placeholder="Escribe el nombre..." autocomplete="off" required>
                                    <option value="">Seleccionar médico...</option>
                                    <% medicos.forEach(m => { %>
                                        <option value="<%= m._id %>">Dr. <%= m.nombre %> <%= m.apellido %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Fecha de la Cita</label>
                                <input type="date" name="fecha" class="form-control" required 
                                       min="<%= new Date().toISOString().split('T')[0] %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Hora</label>
                                <input type="time" name="hora" class="form-control" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Motivo de la consulta / Notas de Recepción</label>
                            <textarea name="motivo" class="form-control" rows="2" 
                                      placeholder="Ej: El paciente llama para revisión de exámenes..." required></textarea>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-dark fw-bold px-4">
                                <i class="bi bi-save me-1"></i> Guardar Cita Confirmada
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Configuramos el buscador de Pacientes
        new TomSelect("#select-paciente", {
            create: false,         // Evita que el usuario invente pacientes que no existen
            sortField: {
                field: "text",
                direction: "asc"   // Ordena la lista alfabéticamente
            }
        });

        // Configuramos el buscador de Médicos
        new TomSelect("#select-medico", {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            }
        });
    });
</script>