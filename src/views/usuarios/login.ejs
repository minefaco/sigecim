<% layout('layouts/main') %>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <h3 class="text-center mb-4">SIGECIM | Acceso</h3>
                <% if (locals.error) { %>
                <div class="alert alert-danger text-center" role="alert">
                <%= error %>
                </div>
                <% } %>
                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label class="form-label">Correo Electrónico</label>
                        <input type="email" name="email" class="form-control" placeholder="admin@sigecim.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <input type="password" name="password" class="form-control" required>
                    </div>
                    <div class="d-grid">
                        <input type="submit" class="btn btn-primary w-100" value="Ingresar al Sistema">
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>