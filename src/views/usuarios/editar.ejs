<% layout('layouts/main') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="bi bi-pencil-square"></i> Editar Usuario: <%= usuario.nombre %>
                </div>
                <div class="card-body">
                    <form action="/usuarios/editar/<%= usuario._id %>?_method=PUT" method="POST">
                        
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" name="nombre" class="form-control" value="<%= usuario.nombre %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Apellido</label>
                            <input type="text" name="apellido" class="form-control" value="<%= usuario.apellido %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" value="<%= usuario.email %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Rol del Usuario</label>
                            <select name="rol" class="form-select">
                                <option value="Admin" <%= usuario.rol === 'Admin' ? 'selected' : '' %>>Administrador</option>
                                <option value="Medico" <%= usuario.rol === 'Medico' ? 'selected' : '' %>>Médico</option>
                                <option value="Paciente" <%= usuario.rol === 'Paciente' ? 'selected' : '' %>>Paciente</option>
                            </select>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold">Actualizar Datos</button>
                            <a href="/usuarios" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>