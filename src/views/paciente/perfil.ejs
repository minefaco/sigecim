<% layout('layouts/main') %>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                <div class="bg-success py-3 px-4 text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-person-vcard"></i> Ficha Médica Digital</h4>
                    <span class="badge bg-white text-success fw-bold">SIGECIM ID: <%= paciente.documento %></span>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-8">
                            <h2 class="text-primary mb-1"><%= paciente.nombre %> <%= paciente.apellido %></h2>
                            <p class="text-muted"><i class="bi bi-envelope"></i> <%= paciente.email %></p>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <div class="p-3 border rounded bg-light text-center">
                                <small class="text-muted d-block">Tipo de Sangre</small>
                                <strong class="fs-3 text-danger"><%= paciente.tipoSangre || 'No definido' %></strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-white fw-bold"><i class="bi bi-hospital text-success"></i> Datos Clínicos</div>
                        <div class="card-body">
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>EPS:</span>
                                    <span class="fw-bold"><%= paciente.eps || 'No asignada' %></span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>Teléfono:</span>
                                    <span class="fw-bold"><%= paciente.telefono || 'No registrado' %></span>
                                </li>
                                <li class="list-group-item mt-3 border-0">
                                    <span class="d-block mb-2"><i class="bi bi-exclamation-octagon text-danger"></i> <strong>Alergias:</strong></span>
                                    <% if(paciente.alergias && paciente.alergias.length > 0) { %>
                                        <% paciente.alergias.forEach(alergia => { %>
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle me-1"><%= alergia %></span>
                                        <% }) %>
                                    <% } else { %>
                                        <span class="text-muted small italic">No se registran alergias conocidas.</span>
                                    <% } %>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-white fw-bold"><i class="bi bi-telephone-outbound text-primary"></i> En Caso de Emergencia</div>
                        <div class="card-body text-center py-4">
                            <% if(paciente.contactoEmergencia && paciente.contactoEmergencia.nombre) { %>
                                <h5 class="mb-1"><%= paciente.contactoEmergencia.nombre %></h5>
                                <p class="text-muted mb-3">Relación: <%= paciente.contactoEmergencia.parentesco || 'Familiar' %></p>
                                <a href="tel:<%= paciente.contactoEmergencia.telefono %>" class="btn btn-primary">
                                    <i class="bi bi-telephone-fill"></i> <%= paciente.contactoEmergencia.telefono %>
                                </a>
                            <% } else { %>
                                <div class="text-muted p-3">
                                    <i class="bi bi-info-circle display-6 d-block mb-2"></i>
                                    No hay contacto de emergencia registrado.
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="/dashboard" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver al Panel</a>
                <button class="btn btn-outline-primary ms-2"><i class="bi bi-printer"></i> Imprimir Ficha</button>
            </div>
        </div>
    </div>
</div>