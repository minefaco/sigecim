<% layout('layouts/main') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar-check text-primary"></i> Mis Citas Programadas</h2>
        <a href="/citas/agendar" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nueva Cita</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Médico</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (citas.length > 0) { %>
                            <% citas.forEach(cita => { %>
                                <tr class="align-middle">
                                    <td><%= new Date(cita.fecha).toLocaleDateString() %></td>
                                    <td><%= cita.hora %></td>
                                    <td>Dr. <%= cita.medico.nombre %> <%= cita.medico.apellido %></td>
                                    <td><small><%= cita.motivo %></small></td>
                                    <td>
                                        <% if(cita.estado === 'Pendiente') { %>
                                            <span class="badge bg-warning text-dark">Pendiente</span>
                                        <% } else if(cita.estado === 'Confirmada') { %>
                                            <span class="badge bg-success">Confirmada</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary"><%= cita.estado %></span>
                                        <% } %>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger" title="Cancelar Cita">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar-x display-4 d-block mb-2"></i>
                                    Aún no tienes citas programadas.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>